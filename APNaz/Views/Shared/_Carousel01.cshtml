@{
    /* For Carousel Display */
    string extension = ".jpg";
    string folder = "pictures/01/";

    string folderURL = "/content/gallery/" + folder;    
    int count= Directory.GetFiles("wwwroot" + folderURL, "*" + extension).Length;
}

<!-- Row -->
<div class="row gx-0 gx-lg-4 pb-0 pb-lg-4">	

	<!-- Card -->
	<div class="my-card-body bg-gray-lighter p-3 col-12 h-100 mx-auto">

        <!-- Carousel for Picture slides -->
		<div class="carousel slide pointer-event" id="CarouselControl01" data-bs-ride="carousel" >

			<!-- The slideshow -->
			<div class="my-rounded carousel-inner" id="CarouselItems01" >(Pictures List gets placed here)</div>

			<!-- Left And right controls -->
			<a class="carousel-control-prev" href="#CarouselControl01" role="button" data-bs-slide="prev" ></a>
			<a class="carousel-control-next" href="#CarouselControl01" role="button" data-bs-slide="next" ></a>

		</div>
	</div>
	
</div>

<script>

	var text = "";
	var altText = ""
	var i = @count;
	var imageLocation = "@folderURL";

	// Create the needed "active" element
	text = "<div class='carousel-item active'><img class='d-block w-100' src='" + imageLocation.concat("000".concat(i).slice(-3)) + "@extension' alt='" + altText.concat("000".concat(i).slice(-3)) + "' /></div>";
	i--;

	// Add the rest of the elements
	while (i > 0) {
		text += "<div class='carousel-item'><img class='d-block w-100' src='" + imageLocation.concat("000".concat(i).slice(-3)) + "@extension' alt='" + altText.concat("000".concat(i).slice(-3)) + "' /></div>";
		i--;
	}

	document.getElementById("CarouselItems01").innerHTML = text;

</script>