<!-- Shared Gallery.cshtml -->
@{
    string imagesFolder = "Gallery";
    string currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "Shared";
    string imagefolder = ViewData["ViewName"]?.ToString() ?? ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var displayData = ImageDisplayHelper.GetImageData(imagesFolder, currentController, imagefolder);
    var folders = displayData.Folders;
    var currentDisplay = displayData.CurrentDisplay;
    var currentImageFolder = displayData.ImageFolder;
    var files = displayData.Files;
    var thumbnailsPath = displayData.ThumbnailsPath;
    var backgroundImage = displayData.BackgroundImage;

    // Gallery type (used in html heading display)
    var galleryType = currentController.Contains("slide", StringComparison.OrdinalIgnoreCase)
        ? "Slideshows"
        : "Galleries";
    galleryType ??= "Galleries"; // Set default if null

    // Target View Slideshow.cshtml or Gallery.cshtml (for the Folder Link Buttons)
    var targetView = currentController.Contains("slide", StringComparison.OrdinalIgnoreCase)
        ? "Gallery" // send someplace else
        : "Gallery";
    targetView ??= "Gallery"; // Set default if null
}

<!-- Go to Top button -->
<button type="button" onclick="topFunction()" id="top-button" title="Go to top">Top</button>

<!-- Link Button Menu -->
<div class="row gx-0 gx-lg-4 justify-content-center g-1 g-lg-3 mt-2 mb-3">

    <!-- Back Link Button -->
    <div class="col-1 menu-item">
        <div class="bg-danger text-center p-0 border border border-dark rounded" style="width:50px; height: 35px;">
            <a class="menu-link text-dark w-100" style="height: 34px; display: flex; align-items: center;" href="/@currentController">
                <img src="/lib/svg/buttons/back-white.svg" alt="Back" style="height: 24px;">
            </a>
        </div>
    </div>

    <!-- Link Buttons -->
    @foreach (var folder in folders)
    {
        <div class="col-1 menu-item" data-viewName="@folder">
            <div id="@folder" class="bg-gray-lighter text-center p-0 border border-dark rounded">
                <a id="@folder-link" class="menu-link text-dark w-100" asp-controller="@currentController" asp-action="@targetView" asp-route-viewName="@folder">@folder</a>
            </div>
        </div>
    }
</div>

@if (galleryType == "Slideshows")
{
    <!-- The Slideshow -->
    <div class="container ms-auto me-auto pb-lg-3">
        <div class="mx-sm-1 mx-md-0 carousel slide pb-0 pointer-event my-rounded" id="CarouselControl" data-bs-ride="carousel">

            <div class="my-rounded carousel-inner shadow" id="CarouselItems">

                @foreach (var file in files)
                {
                    <div class='bg-gray-lighter p-2 carousel-item @(file == files.First() ? "active" : "")'>
                        <img class='d-block w-100'
                             src="@Url.Content(System.IO.Path.Combine("/", imagesFolder, currentDisplay, imagefolder, System.IO.Path.GetFileNameWithoutExtension(file) + "_thumb.jpg").Replace("\\", "/"))"
                             alt="@System.IO.Path.GetFileNameWithoutExtension(file)" />
                    </div>
                }

            </div>

            <!-- Left And right controls -->
            <a class="carousel-control-prev" href="#CarouselControl" role="button" data-bs-slide="prev"></a>
            <a class="carousel-control-next" href="#CarouselControl" role="button" data-bs-slide="next"></a>

        </div>
    </div>
}
else
{
    <!-- Gallery Images -->
    <div id="images-container" class="row g-0 g-sm-2 g-lg-2" style="display: none">

        <!-- Display each Image file and filename -->
        @foreach (var file in files)
        {
            <div class="col-12 col-sm-12 col-md-6 col-lg-4 col-xl-3 col-xxl-3 mb-3">

                <!-- Link to file -->
                <a class="menu-link d-block text-center bg-gray-lighter" href="@Url.Content(file)" target="_blank" title="Full-Screen">

                    <!-- file_thumb -->
                    <img class="w-100 img-fluid mx-auto" data-src="@Url.Content(System.IO.Path.Combine("/", imagesFolder, currentDisplay, imagefolder, System.IO.Path.GetFileNameWithoutExtension(file) + "_thumb.jpg").Replace("\\", "/"))" alt="_Click Me_" />

                    <!-- file name (max of 30 characters shown) -->
                    <div class="text-black text-center pt-1">
                        @System.IO.Path.GetFileNameWithoutExtension(file).Substring(0, Math.Min(30, System.IO.Path.GetFileNameWithoutExtension(file).Length))
                    </div>
                </a>
            </div>
        }
    </div>
}

<!-- Spacing for Large Screens if needed -->
<div class="slideshow-view-bottom-spacing"></div>

<!-- Replaces the background-image -->
<script>
    $("body").css("background-image", "url('../@Url.Content(backgroundImage)')");
</script>

<!-- Toggle the Current Menu Button to indicate it is selected -->
<script>
    var mainElement = document.getElementById("@imagefolder");
    var secondaryElement = document.getElementById("@imagefolder-link");

    mainElement.classList.toggle("bg-gray-lighter");
    mainElement.classList.toggle("bg-gray-dark");
    mainElement.style.pointerEvents = 'none';

    secondaryElement.classList.toggle("text-dark");
    secondaryElement.classList.toggle("text-light");
    secondaryElement.classList.add("selected");
</script>
